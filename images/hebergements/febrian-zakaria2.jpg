          <!-- sstheme/cipmap_otherpages.tpl.php: -->
<div class="mainimagewrapper ">
  <div class="mainimage">
    <div class="img"><picture><source srcset="https://www.maisonapart.com/images/auto/640-480-c/20130530_142930_20130426_163807_p1070088.webp" media="(min-width: 430px)"/><source srcset="https://www.maisonapart.com/images/auto/430-322-c/20130530_142930_20130426_163807_p1070088.webp" media="(min-width: 100px)"/><img width="640" height="480" alt="Pierres diff&eacute;rentes - H&ocirc;tel-Dieu Marseille" title="Pierres diff&eacute;rentes - H&ocirc;tel-Dieu Marseille" class="zoomable" data-pin-description="L&#039;H&ocirc;tel-Dieu de Marseille, de l&#039;h&ocirc;pital &agrave; l&#039;h&ocirc;tel de luxe"     src="https://www.maisonapart.com/images/auto/640-480-c/20130530_142930_20130426_163807_p1070088.webp" srcset="https://www.maisonapart.com/images/auto/640-480-c/20130530_142930_20130426_163807_p1070088.webp 640w,https://www.maisonapart.com/images/auto/430-322-c/20130530_142930_20130426_163807_p1070088.webp 430w"/></picture></div>
